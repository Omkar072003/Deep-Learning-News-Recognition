{
  "openapi": "3.0.0",
  "info": {
    "title": "Content Recognition API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/analyze/image": {
      "post": {
        "summary": "Analyze an image",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Analysis results" }
        }
      }
    }
  }
}